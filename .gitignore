# Node
node_modules/
npm-debug.log*
yarn-error.log*

# Python venv + caches
.venv/
__pycache__/
*.pyc

# TTS model + voice caches (downloaded on first use)
models/
voices/
*.onnx
*.onnx.json
tts_models/
.cache/
.local/share/tts/

# Build output (render, capture, assemble, serve all write here)
out/
renders/
snapshots/

# Captured frames + generated media
frames/
*.mp4
*.wav
*.mp3
*.aiff
*.png

# README showcase video is a shipped repository asset, not build output.
!assets/narova-skill-reel.mp4

# Narova generated projects keep editable source, including local source media.
# generated/.gitignore excludes each project's output and scratch directories.
!generated/*/assets/
!generated/*/assets/**

# macOS
.DS_Store
