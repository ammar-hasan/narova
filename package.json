{
  "name": "narova",
  "version": "0.2.0",
  "description": "A scene script becomes a narrated, captioned, kinetic explainer video.",
  "bin": {
    "narova": "bin/narova.js"
  },
  "type": "commonjs",
  "main": "src/pipeline.js",
  "scripts": {
    "narova": "node bin/narova.js",
    "test": "node --test && npm run -s test:py",
    "test:js": "node --test",
    "test:py": "PYTHONPATH=py python3 -m unittest discover -s py/tests"
  },
  "files": [
    "bin/",
    "src/",
    "py/",
    "!py/**/__pycache__",
    "scripts/",
    ".claude/skills/",
    "SPEC.md",
    "LEARNINGS.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
