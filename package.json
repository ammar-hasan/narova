{
  "name": "narova",
  "version": "0.3.0",
  "description": "A scene script becomes a narrated, captioned video. narova writes the words and the voice; HyperFrames draws the pictures.",
  "bin": {
    "narova": "skills/narova/tool/bin/narova.js"
  },
  "type": "commonjs",
  "main": "skills/narova/tool/src/pipeline.js",
  "scripts": {
    "narova": "node skills/narova/tool/bin/narova.js",
    "test": "npm run -s test:js && npm run -s test:py",
    "test:js": "node --test 'skills/narova/tool/test/*.test.js'",
    "test:py": "PYTHONPATH=skills/narova/tool/py python3 -m unittest discover -s skills/narova/tool/py/tests"
  },
  "files": [
    "skills/",
    ".claude/",
    "scripts/",
    "SPEC.md",
    "LEARNINGS.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
